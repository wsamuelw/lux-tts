# ============================================
# STEP 1: CLONE GITHUB & INSTALL DEPENDENCIES
# ============================================
print("=" * 60)
print("📥 STEP 1: Setting up LuxTTS")
print("=" * 60)
print("Cloning repository and installing dependencies...")

